# Datadog 설정 (Azure App Service > Configuration > Application Settings 에 추가)
DD_API_KEY=your_datadog_api_key_here
DD_SITE=datadoghq.com          # 또는 datadoghq.eu, us3.datadoghq.com 등
DD_SERVICE=azure-sample-app
DD_ENV=dev                      # dev / staging / prod
DD_VERSION=1.0.0

# Datadog APM (코드 레벨 트레이싱)
DD_TRACE_ENABLED=true
DD_RUNTIME_METRICS_ENABLED=true

# 로그 연동 (선택)
DD_LOGS_ENABLED=true
DD_LOGS_INJECTION=true
